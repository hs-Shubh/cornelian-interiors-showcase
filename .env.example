# Supabase (required for leads, inquiries, custom orders, blog)
# Get from: Supabase Dashboard → Project Settings → API
# Use ONLY the anon (public) key in the frontend. Never use the service_role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Site URL (for sitemap, canonical, OG)
VITE_SITE_URL=https://cornelianinteriors.com
